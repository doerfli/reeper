<div>
  <span class="heading_1"><%=t 'recipes.new_url' %></span>
</div>

<div class="mt-4">
  <%= form_tag url_imports_path, method: :post do %>
    <div class="mb-4">
      <div class="mb-2">
        <label for="url"><%= t 'url_import.url_label' %></label>
      </div>
      <div>
        <%= text_field_tag :url,
                           params[:url],
                           id: 'url',
                           required: true,
                           autofocus: true,
                           placeholder: t('url_import.url_placeholder'),
                           autocomplete: 'off',
                           inputmode: 'url' %>
      </div>
    </div>

    <div class="mt-4">
      <button type="submit"
              class="button">
        <i class="fas fa-link"></i>
        <%= t 'url_import.submit' %>
      </button>
    </div>
  <% end %>
</div>
