DB_HOST=db

# OpenAI API Configuration
#OPENAI_API_KEY=your_openai_api_key_here

# Optional: Override OCR cleanup prompts per language
# OPENAI_CLEANUP_PROMPT_EN=Your custom English prompt here...
# OPENAI_CLEANUP_PROMPT_DE=Your custom German prompt here...

# Optional: Override OpenAI models/prompt files (defaults: gpt-5.4-nano / config/prompts/openai_*.txt)
# OPENAI_OCR_MODEL=gpt-5.4-nano
# OPENAI_OCR_PROMPT_FILE=openai_ocr.txt
# OPENAI_MARKDOWN_MODEL=gpt-5.4-nano
# OPENAI_MARKDOWN_PROMPT_FILE=openai_markdown.txt
# OPENAI_URL_MODEL=gpt-5.4-nano
# OPENAI_URL_PROMPT_FILE=openai_url.txt

# Mistral AI API Configuration (required for Mistral + OpenAI OCR method)
# MISTRAL_API_KEY=your_mistral_api_key_here

# Jina.ai API Configuration (optional — free tier works without a key)
# JINA_API_KEY=your_jina_api_key_here
