DB_HOST=db

# OpenAI API Configuration
#OPENAI_API_KEY=your_openai_api_key_here

# Optional: Override OCR cleanup prompts per language
# OPENAI_CLEANUP_PROMPT_EN=Your custom English prompt here...
# OPENAI_CLEANUP_PROMPT_DE=Your custom German prompt here...

# Optional: Override OpenAI stored prompt IDs/versions
# OPENAI_PROMPT_OCR_ID=pmpt_...
# OPENAI_PROMPT_OCR_VERSION=2
# OPENAI_MARKDOWN_PROMPT_ID=pmpt_...
# OPENAI_MARKDOWN_PROMPT_VERSION=2
# OPENAI_URL_PROMPT_ID=pmpt_...          # Required for URL import feature
# OPENAI_URL_PROMPT_VERSION=1

# Mistral AI API Configuration (required for Mistral + OpenAI OCR method)
# MISTRAL_API_KEY=your_mistral_api_key_here

# Jina.ai API Configuration (optional — free tier works without a key)
# JINA_API_KEY=your_jina_api_key_here
